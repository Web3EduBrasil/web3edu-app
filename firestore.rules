rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── Trilhas (leitura pública, escrita apenas pelo backend/admin) ──────────
    match /trails/{trailId} {
      allow read: if true;
      allow write: if false; // Apenas Admin SDK

      match /contents/{sectionId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Programas (leitura pública, escrita apenas pelo backend/admin) ────────
    match /programs/{programId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Usuários ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      // O próprio usuário pode ler e escrever seu perfil
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);

      // Progresso nas trilhas
      match /trailsProgress/{trailId} {
        allow read:  if isOwner(uid);
        allow write: if isOwner(uid);
      }

      // Progresso nos programas
      match /programsProgress/{programId} {
        allow read:  if isOwner(uid);
        allow write: if isOwner(uid);
      }
    }

    // ── Whitelist de NFTs (airdrop de trilhas) ────────────────────────────────
    match /whitelist/{uid} {
      // Apenas o próprio usuário pode ler; escrita somente pelo backend
      allow read:  if isOwner(uid);
      allow write: if false; // Apenas via API route autenticada (Admin SDK)
    }

    // ── Whitelist de programas ────────────────────────────────────────────────
    match /programWhitelist/{uid} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── Leaderboard (leitura pública — só campos públicos via API) ────────────
    // Acesso direto bloqueado; a API /api/leaderboard usa Admin SDK.
    // Se quiser permitir leitura direta do cliente, descomente abaixo:
    // match /users/{uid} {
    //   allow read: if true;  // cuidado: expõe dados privados
    // }

    // ── Regra catch-all: bloqueia tudo que não foi explicitamente permitido ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
