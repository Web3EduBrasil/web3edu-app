# 
# FIREBASE (Client SDK  exposto no browser)
# Console: https://console.firebase.google.com  Configura��es do Projeto  Seus apps
# 
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# 
# FIREBASE ADMIN (Server-side  API routes e verifyAuth)
# Console: Configura��es do Projeto  Contas de servi�o  Gerar nova chave privada
# Cole o JSON inteiro (ou em base64) na vari�vel abaixo
# 
FIREBASE_ADMIN_SERVICE_ACCOUNT=

# 
# WEB3AUTH
# Dashboard: https://dashboard.web3auth.io
#   CLIENT_ID  Infrastructure  Plug and Play  seu projeto
#   VERIFIER   Auth Verifiers  Custom JWT Verifier (configurado com Firebase)
#   NETWORK    sapphire_devnet (teste) ou sapphire_mainnet (producao)
# 
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=
NEXT_PUBLIC_WEB3AUTH_VERIFIER=
NEXT_PUBLIC_WEB3AUTH_NETWORK=sapphire_devnet

# 
# ALCHEMY
# Dashboard: https://dashboard.alchemy.com  Apps  View Key
#   RPC_TARGET  URL completa ex: https://eth-sepolia.g.alchemy.com/v2/SUA_KEY
#   API_KEY     somente a chave, ex: SUA_KEY  (usada para buscar NFTs do usuario)
# 
NEXT_PUBLIC_ALCHEMY_RPC_TARGET=
NEXT_PUBLIC_ALCHEMY_API_KEY=

# 
# PINATA (IPFS  server-side, NUNCA usar NEXT_PUBLIC_)
# Dashboard: https://app.pinata.cloud  API Keys  New Key
# 
PINATA_JWT=

# 
# CONTRATO NFT (Sepolia)
# Endereco do contrato ERC-721 ja deployado
# 
NEXT_PUBLIC_CONTRACT_ADDRESS=0x8984b78F102f85222E7fa9c43d37d84E087B1Be8

# 
# APP
#   BUILD_ENV  "production" ativa redirect URL de producao no Web3Auth
#   APP_LINK   URL publica da aplicacao (sem barra no final)
# 
NEXT_PUBLIC_BUILD_ENV=development
NEXT_PUBLIC_APP_LINK=http://localhost:3000

# 
# SEED (rota /api/admin/seed-trail  use qualquer string secreta)
# 
SEED_SECRET=
