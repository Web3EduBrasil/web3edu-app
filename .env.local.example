# Copy this file to .env.local and fill values

# Firebase (client) - required for auth/storage/firestore
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH=your-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-storage-bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Web3Auth
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your-web3auth-client-id
NEXT_PUBLIC_WEB3AUTH_VERIFIER=your-web3auth-verifier
NEXT_PUBLIC_WEB3AUTH_NETWORK=sapphire_devnet

# App / build environment
NEXT_PUBLIC_BUILD_ENV=development
NEXT_PUBLIC_APP_LINK=http://localhost:3000

# Optional: Alchemy RPC
NEXT_PUBLIC_ALCHEMY_RPC_TARGET=https://eth-sepolia.alchemyapi.io/v2/YOUR_KEY
